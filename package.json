{
  "name": "ai-repo-inspector",
  "version": "0.1.0",
  "description": "AI-First Intern Assessment starter — repair and extend an AI-assisted repository inspector.",
  "private": true,
  "type": "module",
  "bin": {
    "inspector": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "inspector": "tsx src/cli.ts",
    "mcp-server": "tsx src/mcp-server.ts",
    "pretest": "node test/fixtures/setup-sample-repo.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
